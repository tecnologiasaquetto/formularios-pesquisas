# Supabase Configuration
# Copie este arquivo para .env.local e preencha com seus dados do Supabase

# URL do seu projeto Supabase
REACT_APP_SUPABASE_URL=https://your-project-id.supabase.co

# Chave anônima (pode ser exposta no frontend)
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here

# Chave de serviço (NUNCA expor no frontend - uso apenas no backend)
REACT_APP_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Exemplo real:
# REACT_APP_SUPABASE_URL=https://abcdefgh1234.supabase.co
# REACT_APP_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# REACT_APP_SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
