# Supabase Configuration
# Configure estas variáveis no Vercel em: Settings > Environment Variables

# URL do seu projeto Supabase (obrigatório)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Chave anônima - pode ser exposta no frontend (obrigatório)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Chave de serviço - APENAS para funcionalidades admin (opcional)
# ATENÇÃO: Não expor no frontend! Usar apenas em scripts server-side
VITE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Para compatibilidade com código legado
REACT_APP_SUPABASE_URL=https://your-project-id.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here
